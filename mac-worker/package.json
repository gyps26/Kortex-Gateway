{
  "name": "mycrmsim-worker",
  "version": "1.0.0",
  "description": "Local macOS iMessage Worker Daemon",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac"
  },
  "build": {
    "appId": "com.mycrmsim.worker",
    "productName": "MyCRMSIM Worker",
    "mac": {
      "target": "zip",
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.0.0",
    "sqlite3": "^5.1.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2"
  }
}
